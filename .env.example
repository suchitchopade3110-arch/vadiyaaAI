# ── VaidyaAI — Environment Variables ─────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit the real `.env`.

# ── App ───────────────────────────────────────────────────────────────────────
# development | production — controls docs exposure, CORS enforcement, log level
APP_ENV=development
# DEBUG | INFO | WARNING | ERROR — defaults to INFO; use DEBUG only in dev
LOG_LEVEL=INFO
# Required. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme-generate-a-long-random-secret
# Optional — falls back to SECRET_KEY when unset. Used to sign QR report-access tokens.
QR_SECRET_KEY=changeme-generate-a-separate-random-secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vaidyaai
POSTGRES_USER=vaidya
# Required. No default — set a real password.
POSTGRES_PASSWORD=changeme-set-a-strong-password
# Optional — overrides the POSTGRES_* fields above with a single DSN if set.
DATABASE_URL=

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM / RAG ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-changeme
GROQ_API_KEY=gsk-changeme
GROQ_MODEL=llama-3.1-8b-instant
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_URL=http://localhost:8001
CHROMA_PATH=data/chromadb
OLLAMA_BASE_URL=http://localhost:11434
# openai | ollama
LLM_PROVIDER=openai

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# ── Safety / Confidence Thresholds ───────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.65
MIN_CONFIDENCE_THRESHOLD=0.30
HIGH_CONFIDENCE_THRESHOLD=0.80
MIN_SOURCES_REQUIRED=2

# ── Celery Task Timeouts (seconds) ───────────────────────────────────────────
TASK_SOFT_TIME_LIMIT=120
TASK_HARD_TIME_LIMIT=300
IMAGE_TASK_TIMEOUT=120
TEXT_TASK_TIMEOUT=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Required (no localhost default) when APP_ENV=production.
CORS_ORIGINS=http://localhost:3000

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Request Safety Net ────────────────────────────────────────────────────────
# Hard ceiling on request handling time; long-running work belongs in Celery.
REQUEST_TIMEOUT_SECONDS=30
